<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Owner Dashboard</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; font-family: Arial, sans-serif; }
        body { background-color: #f4f6f9; padding: 30px; }
        header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; }
        h1 { color: #333; }
        .add-btn { background-color: #28a745; color: white; padding: 10px 20px; text-decoration: none; border-radius: 5px; font-weight: bold; }
        .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 20px; }
        .card { background: white; border-radius: 8px; overflow: hidden; box-shadow: 0 4px 6px rgba(0,0,0,0.1); display: flex; flex-direction: column; }
        .card img { width: 100%; height: 300px; object-fit: cover; }
        .card-content { padding: 15px; flex-grow: 1; display: flex; flex-direction: column; justify-content: space-between; }
        .card h3 { margin-bottom: 10px; color: #222; font-size: 1.2rem; }
        .price { color: #e44d26; font-weight: bold; margin-bottom: 15px; }
        
        .booking-stats {
            background-color: #f8f9fa;
            border: 1px solid #eee;
            padding: 10px;
            border-radius: 5px;
            margin-bottom: 15px;
            font-size: 0.9rem;
            color: #555;
        }
        .booking-stats div {
            margin-bottom: 4px;
        }
        .booking-stats strong {
            color: #333;
        }

        .remove-btn { background-color: #dc3545; color: white; border: none; padding: 8px 12px; width: 100%; border-radius: 4px; cursor: pointer; font-weight: bold; transition: background 0.2s; margin-top: 5px; }
        .remove-btn:hover { background-color: #c82333; }
        .no-movies { grid-column: 1 / -1; text-align: center; color: #777; padding: 50px; font-size: 1.2rem; }
    </style>
</head>
<body>

    <header>
        <h1>Owner Dashboard</h1>
        <a href="/owner/create" class="add-btn">+ Add New Movie</a>
    </header>

    <main class="grid">
        <% if (movies && movies.length > 0) { %>
            <% movies.forEach(movie => { %>
                <div class="card">
                    <img src="<%= movie.movieimage || 'https://via.placeholder.com/250x300?text=No+Image' %>" alt="Movie Poster">
                    <div class="card-content">
                        <div>
                            <h3><%= movie.moviename %></h3>
                            <p class="price">Rs <%= movie.movieprice %></p>
                            
                            <% 
                                let totalBookings = 0;
                                let standardBookings = 0;
                                let vipBookings = 0;
                                let deluxeBookings = 0;
                                let seatsLeft = 0; // 🟢 Added tracker variable

                                if (movie.seating && movie.seating.length > 0) {
                                    movie.seating.forEach(row => {
                                        if (row.seats && row.seats.length > 0) {
                                            row.seats.forEach(seat => {
                                                if (seat.status === 'booked') {
                                                    totalBookings++;
                                                    if (seat.type === 'standard') standardBookings++;
                                                    else if (seat.type === 'vip') vipBookings++;
                                                    else if (seat.type === 'deluxe') deluxeBookings++;
                                                } else if (seat.status === 'available') {
                                                    seatsLeft++; // 🟢 Increment for open seats
                                                }
                                            });
                                        }
                                    });
                                }
                            %>

                            <div class="booking-stats">
                                <div><strong>Total Bookings:</strong> <%= totalBookings %></div>
                                <div>• Standard Booked: <%= standardBookings %></div>
                                <div>• VIP Booked: <%= vipBookings %></div>
                                <div>• Deluxe Booked: <%= deluxeBookings %></div>
                                <div style="margin-top: 6px; padding-top: 4px; border-top: 1px dashed #ddd;">
                                    <strong>Seats Left:</strong> <%= seatsLeft %>
                                </div>
                            </div>
                        </div>
                        
                        <form action="/owner/movie/delete/<%= movie._id %>" method="POST" onsubmit="return confirm('Are you sure you want to delete this movie?');">
                            <button type="submit" class="remove-btn">Remove Movie</button>
                        </form>
                    </div>
                </div>
            <% }) %>
        <% } else { %>
            <div class="no-movies">
                <p>You haven't posted any movies yet.</p>
            </div>
        <% } %>
    </main>

</body>
</html>