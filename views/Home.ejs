<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/stylesheets/Home.css"/>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Mulish:wght@300;400;600;700;900&family=Bebas+Neue&display=swap" rel="stylesheet">
    <script src="https://kit.fontawesome.com/4c7708918a.js" crossorigin="anonymous"></script>
    <title>CineBook – Movies &amp; Tickets</title>
</head>
<body>

    <!-- ── PRIMARY NAV ── -->
    <nav class="fnav">
        <div class="left">
            <img src="load.png" alt="CineBook logo">
            <input type="text" id="search-input" placeholder="Search movies…" autocomplete="off"/>
        </div>
        <div class="right">
            <p>Location</p>
            <button id="logoutbutton">Sign Out</button>
            <i class="fa-solid fa-bars" id="menu-toggle" aria-label="Menu"></i>
        </div>
    </nav>

    <!-- ── SECONDARY NAV ── -->
    <nav class="sec-nav">
        <div class="s-left">
            <p>Movies</p>
            <p>Bookings</p>
            <p>Group</p>
        </div>
        <div class="s-right">
            <p>List Your Show</p>
            <p>Corporates</p>
            <p>Offers</p>
        </div>
    </nav>

    <!-- ── MOVIES SECTION ── -->
    <div class="container">
        <h2>Now Showing</h2>

        <div class="card-scroll" id="movie-grid">
            <% movies.forEach(function(movie){ %>
                <% if(movie.moviename){ %>
                <div class="all-image" data-id="<%= movie._id %>">
                    <img
                        src="<%= movie.movieimage %>"
                        alt="<%= movie.moviename %> poster"
                        loading="lazy"
                        onerror="this.src='/default-placeholder.png'"
                    >
                    <h3><%= movie.moviename %></h3>
                    <p><%= movie.genre %></p>
                </div>
                <% } %>
            <% }) %>

            <!-- Empty / no-results state -->
            <div class="no-results" id="no-results">
                <i class="fa-solid fa-film"></i>
                <span>No movies match your search.</span>
            </div>
        </div>
    </div>

    <!-- ── FOOTER ── -->
    <footer class="footer">
        <img src="logo.png" alt="CineBook">
        <div class="icon">
            <i class="fa-brands fa-facebook" aria-label="Facebook"></i>
            <i class="fa-brands fa-square-instagram" aria-label="Instagram"></i>
            <i class="fa-brands fa-twitter" aria-label="Twitter"></i>
            <i class="fa-brands fa-youtube" aria-label="YouTube"></i>
        </div>
        <p class="footer-copy">© 2026 CineBook. All rights reserved.</p>
    </footer>

    <!-- ── SCRIPTS ── -->
    <script>
        /* ---------- Logout ---------- */
        document.getElementById('logoutbutton').addEventListener('click', async () => {
            try {
                const response = await fetch('/logout', {
                    method: 'GET',
                    credentials: 'include'
                });
                if (response.redirected) {
                    window.location.href = response.url;
                } else {
                    console.error('Logout failed:', response.statusText);
                }
            } catch (error) {
                console.error('Error during logout:', error);
            }
        });

        document.addEventListener('DOMContentLoaded', () => {
            const movieCards  = document.querySelectorAll('.all-image');
            const searchInput = document.getElementById('search-input');
            const noResults   = document.getElementById('no-results');

            /* ---------- Live search ---------- */
            if (searchInput) {
                searchInput.addEventListener('input', (e) => {
                    const term = e.target.value.toLowerCase().trim();
                    let visible = 0;

                    movieCards.forEach(card => {
                        const name = card.querySelector('h3').textContent.toLowerCase();
                        const show = name.includes(term);
                        card.style.display = show ? '' : 'none';
                        if (show) visible++;
                    });

                    // Show/hide empty state
                    if (noResults) {
                        noResults.style.display = visible === 0 ? 'flex' : 'none';
                    }
                });
            }

            /* ---------- Card click → movie detail ---------- */
            if (movieCards.length === 0) {
                console.warn('No movie cards found.');
                return;
            }

            movieCards.forEach(card => {
                card.addEventListener('click', () => {
                    const movieId = card.getAttribute('data-id');
                    window.location.href = `/user/movie/${movieId}`;
                });
            });
        });
    </script>
</body>
</html>
