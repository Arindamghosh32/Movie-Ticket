<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Mulish:wght@300;400;600;700;900&family=Bebas+Neue&display=swap" rel="stylesheet">
    <script src="https://kit.fontawesome.com/4c7708918a.js" crossorigin="anonymous"></script>
    <title>Create Movie – CineBook</title>
    <style>
        /* =========================================
           RESET & VARIABLES
        ========================================= */
        *, *::before, *::after {
            margin: 0; padding: 0; box-sizing: border-box;
        }

        :root {
            --red:        #E8132A;
            --red-dark:   #B00F20;
            --red-glow:   rgba(232, 19, 42, 0.18);
            --black:      #0D0D0D;
            --surface:    #161616;
            --surface-2:  #1F1F1F;
            --surface-3:  #2A2A2A;
            --border:     rgba(255,255,255,0.08);
            --white:      #FFFFFF;
            --grey:       #A0A0A0;
            --grey-light: #D4D4D4;
            --green:      #22C55E;
            --orange:     #F97316;
            --purple:     #A855F7;
            --radius-sm:  6px;
            --radius-md:  12px;
            --radius-lg:  20px;
            --transition: 0.25s cubic-bezier(0.4, 0, 0.2, 1);
            --font-display: 'Bebas Neue', sans-serif;
            --font-body:    'Mulish', sans-serif;
        }

        html { scroll-behavior: smooth; }

        body {
            background-color: var(--black);
            color: var(--white);
            font-family: var(--font-body);
            -webkit-font-smoothing: antialiased;
            min-height: 100vh;
        }

        /* =========================================
           TOP ACTION BAR
        ========================================= */
        .top-actions {
            display: flex;
            justify-content: flex-end;
            align-items: center;
            gap: 12px;
            max-width: 1000px;
            margin: 0 auto;
            padding: 20px 24px 0;
        }

        .dashboard-btn,
        .logout-btn {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 9px 20px;
            font-family: var(--font-body);
            font-size: 13px;
            font-weight: 700;
            letter-spacing: 0.4px;
            border-radius: 999px;
            text-decoration: none;
            transition: transform var(--transition), box-shadow var(--transition), background var(--transition);
        }

        .dashboard-btn {
            background: var(--red);
            color: var(--white);
        }

        .dashboard-btn:hover {
            background: var(--red-dark);
            transform: translateY(-1px);
            box-shadow: 0 4px 16px var(--red-glow);
        }

        .logout-btn {
            background: var(--surface-2);
            color: var(--grey-light);
            border: 1px solid var(--border);
        }

        .logout-btn:hover {
            background: var(--surface-3);
            color: var(--white);
            transform: translateY(-1px);
        }

        /* =========================================
           MAIN CONTAINER
        ========================================= */
        .container {
            max-width: 1000px;
            margin: 24px auto 60px;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            padding: 40px 40px 48px;
            box-shadow: 0 24px 64px rgba(0,0,0,0.5);
            animation: fadeUp 0.4s ease both;
        }

        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(20px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        h1 {
            font-family: var(--font-display);
            font-size: clamp(28px, 4vw, 40px);
            letter-spacing: 2px;
            color: var(--white);
            text-align: left;
            margin-bottom: 6px;
        }

        .page-subtitle {
            font-size: 14px;
            color: var(--grey);
            margin-bottom: 36px;
            padding-bottom: 28px;
            border-bottom: 1px solid var(--border);
        }

        .page-subtitle span {
            display: inline-block;
            width: 36px;
            height: 3px;
            background: var(--red);
            border-radius: 2px;
            vertical-align: middle;
            margin-right: 10px;
        }

        /* =========================================
           FORM LAYOUT
        ========================================= */
        form {
            display: flex;
            flex-wrap: wrap;
            gap: 20px;
        }

        .form-group {
            flex: 1 1 calc(50% - 10px);
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .form-group.full {
            flex: 1 1 100%;
        }

        .form-group label {
            font-size: 12px;
            font-weight: 700;
            color: var(--grey);
            letter-spacing: 0.8px;
            text-transform: uppercase;
        }

        .form-group input,
        .form-group select,
        .form-group textarea {
            padding: 11px 14px;
            font-size: 14px;
            font-family: var(--font-body);
            background: var(--surface-2);
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            color: var(--white);
            outline: none;
            transition: border-color var(--transition), box-shadow var(--transition);
            resize: vertical;
        }

        .form-group input::placeholder,
        .form-group textarea::placeholder { color: var(--grey); }

        .form-group input:focus,
        .form-group select:focus,
        .form-group textarea:focus {
            border-color: var(--red);
            box-shadow: 0 0 0 3px var(--red-glow);
        }

        .form-group select option {
            background: var(--surface-2);
            color: var(--white);
        }

        /* Section label */
        .section-label {
            flex: 1 1 100%;
            font-family: var(--font-display);
            font-size: 22px;
            letter-spacing: 1.5px;
            color: var(--white);
            margin-top: 12px;
            padding-top: 24px;
            border-top: 1px solid var(--border);
        }

        /* =========================================
           SEATING AREA
        ========================================= */
        .seating-container {
            flex: 1 1 100%;
            margin-top: 8px;
        }

        /* Screen indicator */
        .screen-bar {
            text-align: center;
            margin-bottom: 32px;
        }

        .screen-bar .screen-line {
            display: block;
            width: 60%;
            height: 4px;
            margin: 0 auto 8px;
            background: linear-gradient(90deg, transparent, var(--grey), transparent);
            border-radius: 2px;
        }

        .screen-bar p {
            font-size: 11px;
            letter-spacing: 3px;
            text-transform: uppercase;
            color: var(--grey);
        }

        /* Legend */
        .seat-legend {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 16px;
            margin-bottom: 28px;
        }

        .legend-item {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 12px;
            color: var(--grey-light);
            font-weight: 600;
        }

        .legend-dot {
            width: 14px;
            height: 14px;
            border-radius: 3px;
            flex-shrink: 0;
        }

        .legend-dot.standard { background: var(--green); }
        .legend-dot.vip      { background: var(--orange); }
        .legend-dot.deluxe   { background: var(--purple); }

        /* Grid */
        .seating-grid {
            display: grid;
            gap: 10px;
            justify-content: center;
            margin-bottom: 12px;
        }

        /* Row wrapper */
        .row {
            display: contents;
        }

        /* Individual seat */
        .seat {
            width: 38px;
            height: 38px;
            border-radius: 6px 6px 3px 3px;
            cursor: pointer;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 10px;
            font-weight: 700;
            font-family: var(--font-body);
            letter-spacing: 0.3px;
            color: rgba(0,0,0,0.75);
            transition: transform var(--transition), box-shadow var(--transition), filter var(--transition);
            position: relative;
            user-select: none;
        }

        /* Cinema chair shape: small "back" on top */
        .seat::before {
            content: '';
            position: absolute;
            top: -4px;
            left: 4px;
            right: 4px;
            height: 4px;
            border-radius: 3px 3px 0 0;
            background: inherit;
            filter: brightness(0.75);
        }

        .seat:hover {
            transform: translateY(-3px) scale(1.08);
            box-shadow: 0 6px 18px rgba(0,0,0,0.4);
            filter: brightness(1.15);
        }

        .seat.standard { background: var(--green); }
        .seat.vip      { background: var(--orange); }
        .seat.deluxe   { background: var(--purple); color: rgba(255,255,255,0.9); }

        /* Hint text */
        .seat-hint {
            text-align: center;
            font-size: 12px;
            color: var(--grey);
            margin-top: 16px;
        }

        /* =========================================
           FORM ACTIONS
        ========================================= */
        .form-actions {
            flex: 1 1 100%;
            display: flex;
            justify-content: center;
            gap: 14px;
            margin-top: 32px;
            flex-wrap: wrap;
        }

        .btn {
            padding: 12px 32px;
            font-family: var(--font-body);
            font-size: 14px;
            font-weight: 700;
            letter-spacing: 0.5px;
            border: none;
            border-radius: 999px;
            cursor: pointer;
            transition: transform var(--transition), box-shadow var(--transition), background var(--transition);
        }

        .btn-outline {
            background: transparent;
            color: var(--white);
            border: 1px solid var(--border);
        }

        .btn-outline:hover {
            background: var(--surface-2);
            transform: translateY(-1px);
        }

        .btn-primary {
            background: var(--red);
            color: var(--white);
        }

        .btn-primary:hover {
            background: var(--red-dark);
            transform: translateY(-2px);
            box-shadow: 0 6px 20px var(--red-glow);
        }

        /* =========================================
           RESPONSIVE
        ========================================= */
        @media (max-width: 720px) {
            .container {
                margin: 16px;
                padding: 28px 20px 36px;
                border-radius: var(--radius-md);
            }

            .form-group {
                flex: 1 1 100%;
            }

            .top-actions {
                padding: 16px 16px 0;
            }

            .seat {
                width: 30px;
                height: 30px;
                font-size: 8px;
            }

            .seating-grid {
                gap: 7px;
            }
        }

        @media (max-width: 480px) {
            .seat { width: 26px; height: 26px; font-size: 7px; }
            .seating-grid { gap: 5px; }
        }

        @media (prefers-reduced-motion: reduce) {
            *, *::before, *::after {
                animation-duration: 0.01ms !important;
                transition-duration: 0.01ms !important;
            }
        }
    </style>
</head>
<body>

    <!-- ── TOP ACTIONS ── -->
    <div class="top-actions">
        <a href="/owner/dashboard" class="dashboard-btn">
            <i class="fa-solid fa-gauge-high"></i> Dashboard
        </a>
        <a href="/logout" class="logout-btn">
            <i class="fa-solid fa-right-from-bracket"></i> Logout
        </a>
    </div>

    <!-- ── MAIN CONTAINER ── -->
    <div class="container">
        <h1>Create Movie</h1>
        <p class="page-subtitle"><span></span>Fill in the details and design your seating layout below.</p>

        <form id="movie-form">

            <!-- Movie details -->
            <div class="form-group">
                <label for="moviename">Movie Name</label>
                <input type="text" id="moviename" name="moviename" placeholder="e.g. Inception" required>
            </div>

            <div class="form-group">
                <label for="movieprice">Ticket Price (₹)</label>
                <input type="number" id="movieprice" name="movieprice" placeholder="e.g. 250" required>
            </div>

            <div class="form-group">
                <label for="movieimage">Movie Image URL</label>
                <input type="text" id="movieimage" name="movieimage" placeholder="https://…" required>
            </div>

            <div class="form-group">
                <label for="genre">Genre</label>
                <select id="genre" name="genre" required>
                    <option value="Thriller">Thriller</option>
                    <option value="Action">Action</option>
                    <option value="Comedy">Comedy</option>
                    <option value="Romantic">Romantic</option>
                </select>
            </div>

            <div class="form-group">
                <label for="moviedate">Release Date</label>
                <input type="date" id="moviedate" name="movieDate" required>
            </div>

            <div class="form-group">
                <label for="location">Location</label>
                <input type="text" id="location" name="Location" placeholder="e.g. Mumbai" required>
            </div>

            <div class="form-group full">
                <label for="movieabout">About the Movie</label>
                <textarea id="movieabout" name="movieAbout" rows="4" placeholder="Short description…"></textarea>
            </div>

            <!-- Seating config -->
            <p class="section-label">Seating Layout</p>

            <div class="form-group">
                <label for="rows">Number of Rows</label>
                <input type="number" id="rows" min="1" max="26" value="10" required>
            </div>

            <div class="form-group">
                <label for="cols">Seats Per Row</label>
                <input type="number" id="cols" min="1" value="10" required>
            </div>

            <!-- Seating grid -->
            <div class="seating-container">
                <div class="screen-bar">
                    <span class="screen-line"></span>
                    <p>Screen this way</p>
                </div>

                <div class="seat-legend">
                    <div class="legend-item">
                        <span class="legend-dot standard"></span> Standard — click once
                    </div>
                    <div class="legend-item">
                        <span class="legend-dot vip"></span> VIP — click twice
                    </div>
                    <div class="legend-item">
                        <span class="legend-dot deluxe"></span> Deluxe — click thrice
                    </div>
                </div>

                <div id="seating-grid" class="seating-grid"></div>
                <p class="seat-hint">Click any seat to cycle through types.</p>
            </div>

            <!-- Buttons -->
            <div class="form-actions">
                <button type="button" class="btn btn-outline" onclick="generateSeating()">
                    <i class="fa-solid fa-rotate"></i> Regenerate Seats
                </button>
                <button type="submit" class="btn btn-primary" id="submit-btn">
                    <i class="fa-solid fa-film"></i> Publish Movie
                </button>
            </div>

        </form>
    </div>

    <!-- ── SCRIPTS (your logic, untouched) ── -->
    <script>
        const seatingGrid = document.getElementById('seating-grid');
        const dateInput   = document.getElementById('moviedate');

        const todayStr = new Date().toISOString().split('T')[0];
        dateInput.min  = todayStr;

        function generateSeating() {
            const rows = parseInt(document.getElementById('rows').value);
            const cols = parseInt(document.getElementById('cols').value);
            seatingGrid.innerHTML = '';

            seatingGrid.style.gridTemplateColumns = `repeat(${cols}, 1fr)`;

            for (let i = 0; i < rows; i++) {
                const rowDiv = document.createElement('div');
                rowDiv.className = 'row';
                rowDiv.setAttribute('data-row', String.fromCharCode(65 + i));

                for (let j = 0; j < cols; j++) {
                    const seat       = document.createElement('div');
                    seat.className   = 'seat standard';
                    seat.textContent = String.fromCharCode(65 + i) + (j + 1);

                    seat.addEventListener('click', () => toggleSeatType(seat));
                    rowDiv.appendChild(seat);
                }

                seatingGrid.appendChild(rowDiv);
            }
        }

        function toggleSeatType(seat) {
            const currentType = seat.classList.contains('standard')
                ? 'standard'
                : seat.classList.contains('vip')
                    ? 'vip'
                    : 'deluxe';

            const nextType = currentType === 'standard' ? 'vip'
                           : currentType === 'vip'      ? 'deluxe'
                           : 'standard';

            seat.className = `seat ${nextType}`;
        }

        document.getElementById('movie-form').addEventListener('submit', async (e) => {
            e.preventDefault();

            const selectedDate = new Date(dateInput.value).setHours(0, 0, 0, 0);
            const systemToday  = new Date().setHours(0, 0, 0, 0);

            if (selectedDate < systemToday) {
                alert("⚠️ You cannot select a date in the past! Please choose today or a future date.");
                dateInput.value = todayStr;
                return;
            }

            const movieDetails = {
                moviename:  document.getElementById('moviename').value,
                movieprice: document.getElementById('movieprice').value,
                movieimage: document.getElementById('movieimage').value,
                movieAbout: document.getElementById('movieabout').value,
                movieDate:  document.getElementById('moviedate').value,
                Location:   document.getElementById('location').value,
                genre:      document.getElementById('genre').value,
                seating:    generateSeatingData()
            };

            console.log('Movie Details:', movieDetails);

            try {
                const response = await fetch('http://localhost:3000/owner/created', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(movieDetails),
                });

                if (response.ok) {
                    const data = await response.json();
                    alert('Movie details submitted successfully');
                    console.log('Response:', data);
                } else {
                    console.error('Error:', response.statusText);
                    alert('Failed to submit movie details');
                }
            } catch (error) {
                console.error('Error:', error);
                alert('An error occurred while submitting movie details');
            }
        });

        function generateSeatingData() {
            const rows = parseInt(document.getElementById('rows').value);
            const cols = parseInt(document.getElementById('cols').value);
            const seatingData = [];

            for (let i = 0; i < rows; i++) {
                const row   = String.fromCharCode(65 + i);
                const seats = [];

                for (let j = 0; j < cols; j++) {
                    const seatEl   = document.querySelector(`[data-row="${row}"] .seat:nth-child(${j + 1})`);
                    const seatType = seatEl.classList.contains('vip')    ? 'vip'
                                   : seatEl.classList.contains('deluxe') ? 'deluxe'
                                   : 'standard';

                    seats.push({
                        seatingNumber: (j + 1).toString(),
                        type:   seatType,
                        status: 'available',
                    });
                }

                seatingData.push({ row, seats });
            }

            return seatingData;
        }

        // Auto-generate on load
        generateSeating();
    </script>
</body>
</html>